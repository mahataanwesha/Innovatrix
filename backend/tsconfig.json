{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    // "rootDir": "./src",
    // "outDir": "./dist",

    // Environment Settings
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "types": ["node"],
    
    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // Stricter Typechecking Options
    "strict": true,
    "skipLibCheck": true
  }
}
